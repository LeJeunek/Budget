// FinanceOS — Prisma schema (Phase 0 + Phase 1 + Phase 2 + Phase 3a + Phase 3b + Phase 4a)
// Scope: auth (Better Auth), Accounts, Transactions, Categories, Tags (Phase 1);
// Budgeting, Savings Goals, Bills, Notifications, and a multi-file Receipt model
// for Transactions (Phase 2); Debt Tracker, Investments (Holding), Recurring
// Income, and the Net Worth Snapshot job (Phase 3a); Financial Goals and
// Subscription Cost Detection's dismissal-tracking (Phase 3b — Net Worth
// History and Analytics' other 11 metrics are pure read layers over existing
// tables and require no schema changes of their own, see below); the
// Transaction Auto-Categorization suggestion/audit-trail table, the Budget
// Advisor/Spending Insights refresh-cache rows, Monthly Summaries, and the
// Financial Health Score's own historical snapshot table (Phase 4a — see
// below; Phase 4a's actual AI provider/prompt/schema code has no Prisma
// model of its own, it only reads/writes the tables below). Modeled per
// docs/product/{budgeting,savings-goals,bills,calendar-and-notifications,
// debt-tracker,investments,recurring-income,financial-goals,analytics,
// net-worth-history,ai-features}.md and docs/architecture/{api-contracts.md,
// Architecture.md,ai-features-design.md}'s Phase 2/3a/3b/4a module-boundary
// sections. See docs/database/{er-diagram,migration-strategy,
// performance-considerations}.md for the full rationale behind every
// modeling decision below.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (Better Auth's required shape — do not rename fields, the adapter
// expects these exact models/columns)
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts AuthAccount[]

  // FinanceOS domain data (Phase 1)
  financialAccounts Account[]
  transactions      Transaction[]
  categories        Category[]
  tags              Tag[]

  // FinanceOS domain data (Phase 2)
  budgets           Budget[]
  budgetCategories  BudgetCategory[]
  goals             Goal[]
  goalContributions GoalContribution[]
  bills             Bill[]
  billOccurrences   BillOccurrence[]
  notifications     Notification[]
  receipts          Receipt[]

  // FinanceOS domain data (Phase 3a)
  debts                 Debt[]
  holdings              Holding[]
  holdingValueHistory   HoldingValueHistoryEntry[]
  dividendEntries       DividendEntry[]
  incomeStreams         IncomeStream[]
  incomeOccurrences     IncomeOccurrence[]
  irregularIncomeEvents IrregularIncomeEvent[]
  netWorthSnapshots     NetWorthSnapshot[]

  // FinanceOS domain data (Phase 3b)
  financialGoals                 FinancialGoal[]
  dismissedSubscriptionMerchants DismissedSubscriptionMerchant[]

  // FinanceOS domain data (Phase 4a)
  categorySuggestions           CategorySuggestion[]
  budgetAdvisorCaches           BudgetAdvisorCache[]
  monthlySummaries              MonthlySummary[]
  spendingInsightsCaches        SpendingInsightsCache[]
  financialHealthScoreSnapshots FinancialHealthScoreSnapshot[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

// Better Auth's own "Account" concept (OAuth provider link), distinct from
// FinanceOS's financial Account model below — kept separate on purpose and
// named AuthAccount here to avoid the collision; Better Auth is configured
// to map to the "account" table regardless of this Prisma model name.
model AuthAccount {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// FinanceOS domain (Phase 1)
// ---------------------------------------------------------------------------

// Single type covering every Phase-1-through-3 account kind. Modeled broadly
// now (per docs/planning/risk-register.md #1) so Phase 3's debt/investment
// accounts extend this instead of requiring a new top-level entity and a
// breaking migration. interestRate is nullable because it's meaningless for
// e.g. CASH or CHECKING.
enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH
  INVESTMENT
  RETIREMENT
  CRYPTO
}

model Account {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         AccountType
  institution  String?
  // Phase 1/2 meaning: manually-entered current balance for every type.
  // Phase 3a addition (Investments, see Holding below): once an Investment/
  // Retirement/Crypto Account has one or more active (non-closed) Holding
  // rows, this column's *meaning* changes to a derived, read-only value — the
  // sum of those holdings' currentValue — kept in sync by
  // features/investments/server/actions.ts writing it back in the same
  // transaction as any holding mutation (create/update/close), never
  // computed fresh by Accounts itself. This is a deliberate, narrow exception
  // to "never store what's derived" — see docs/database/er-diagram.md's
  // Phase 3a design notes for the full reasoning (Accounts must not gain a
  // forward dependency on Investments, and Account.balance already has
  // pre-existing consumers — the Accounts list, the Transaction form's
  // account picker, Dashboard's Net Worth sum — that must keep working
  // unmodified). The column type/constraints are unchanged either way.
  balance      Decimal     @default(0) @db.Decimal(14, 2)
  interestRate Decimal?    @db.Decimal(5, 2)
  color        String      @default("#6366f1") // hex, user-chosen — see naming-standards.md
  // Soft delete: transaction history must survive account removal for
  // analytics/reports in later phases. Never hard-delete an Account.
  archivedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  transactions Transaction[]

  // Phase 3a: an Account may optionally be the one Account a Debt links to
  // (Credit Card case, hybrid Option C — see Debt below) and/or the container
  // for zero or more Holdings (Investment/Retirement/Crypto case). Both are
  // optional and independent — an Account is never required to have either.
  debt     Debt?
  holdings Holding[]

  // Phase 3b: zero or more FinancialGoal rows of type NET_WORTH_SAVINGS_TARGET
  // (measurementBasis: ACCOUNT_SUBSET) may include this Account in their
  // subset — see FinancialGoalAccount below. Purely an inclusion record; an
  // Account never needs to know which goals reference it in normal use, this
  // back-relation exists only because Prisma requires both sides of a
  // relation to be declared.
  financialGoalLinks FinancialGoalAccount[]

  @@index([userId])
  // Better Auth's own OAuth-link model (AuthAccount, above) owns the
  // "account" table name per its adapter contract — this financial Account
  // model maps to a different table name to avoid the collision.
  @@map("financial_account")
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  // Seed categories (Housing, Utilities, ...) are marked isSystem so the UI
  // can prevent deletion/renaming of the Charter's fixed starter set while
  // still allowing user-added categories to be freely edited.
  isSystem  Boolean  @default(false)
  color     String   @default("#94a3b8")
  createdAt DateTime @default(now())

  transactions Transaction[]

  // Phase 2 back-relations. Category itself is unchanged (still hard-delete for
  // custom categories per categories.md AC6) — BudgetCategory.categoryId and
  // Bill.categoryId both use onDelete: SetNull below, the same pattern already
  // established for Transaction.categoryId, so a deleted category never leaves
  // a dangling FK on either new model.
  budgetCategories BudgetCategory[]
  bills            Bill[]

  // Phase 4a back-relation. Category itself is unchanged (still hard-delete
  // for custom categories per categories.md AC6) — CategorySuggestion.
  // suggestedCategoryId uses onDelete: SetNull below, the same pattern
  // already established for Transaction/BudgetCategory/Bill's categoryId, so
  // a deleted category never leaves a dangling FK on a suggestion row either.
  categorySuggestions CategorySuggestion[]

  @@unique([userId, name])
  @@map("category")
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  transactions TransactionTag[]

  @@unique([userId, name])
  @@map("tag")
}

model Transaction {
  id                  String        @id @default(cuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId           String
  account             Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId          String?
  category            Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchant            String
  amount              Decimal       @db.Decimal(14, 2) // positive = income/credit, negative = expense/debit
  date                DateTime      @db.Date // UTC calendar date; see risk-register.md #8 on timezone handling
  notes               String?
  // Split transactions: a parent transaction's amount is divided across
  // categories. parentTransactionId is null for normal/parent transactions;
  // set for the generated split "child" rows, which together must sum to the
  // parent's amount (enforced in features/transactions/server/service.ts, not
  // at the DB level, since Prisma can't express a cross-row sum constraint).
  parentTransactionId String?
  parentTransaction   Transaction?  @relation("TransactionSplits", fields: [parentTransactionId], references: [id], onDelete: Cascade)
  splits              Transaction[] @relation("TransactionSplits")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tags TransactionTag[]

  // Phase 2: the Phase 1 placeholder `receiptUrl: String?` (a single URL) is
  // dropped in favor of a proper one-to-many Receipt model — see Receipt below.
  // Safe to drop outright (not a two-migration rename per migration-strategy.md
  // rule #4): there is no production data yet, and Phase 1 never built any UI
  // that wrote to receiptUrl, so there is nothing to backfill/dual-write.
  receipts Receipt[]

  // Phase 2: the optional Bill occurrence this transaction backs, if any (a
  // Transaction may satisfy at most one BillOccurrence — see BillOccurrence's
  // unique transactionId below). Nullable/optional from this side since most
  // transactions never link to a bill.
  billOccurrence BillOccurrence?

  // Phase 3a: the optional Recurring Income occurrence/event this transaction
  // backs, if any (see IncomeOccurrence/IrregularIncomeEvent below). A single
  // Transaction may back at most one occurrence of *any* kind across the
  // whole product — Bill occurrence, income occurrence, or irregular income
  // event, never more than one of these three. Each target table enforces its
  // own uniqueness independently (billOccurrence above, incomeOccurrence and
  // irregularIncomeEvent below all use @unique transactionId FKs); the
  // cross-table "at most one of any kind" invariant that spans all three is
  // an application-level guard (lib/transaction-link-guard.ts), not
  // expressible as a single database constraint — see this schema's Phase 3a
  // design notes in docs/database/er-diagram.md for why a DB trigger was
  // considered and not added in this phase.
  incomeOccurrence     IncomeOccurrence?
  irregularIncomeEvent IrregularIncomeEvent?

  // Phase 4a: zero or more Transaction Auto-Categorization suggestion/
  // audit-trail rows may reference this transaction over its lifetime (an
  // automatic suggestion, later rejected, followed by a fresh manual
  // "reconsider" suggestion) — see CategorySuggestion below. A plain
  // (non-unique) back-relation, since AC1/AC6 both allow more than one
  // suggestion per transaction across time; "at most one *pending*
  // suggestion at a time" is the invariant, enforced by a real database
  // partial unique index (not just an application-level guard — see
  // CategorySuggestion's own comment for why this table's cron/AUTOMATIC
  // path needed a stronger mechanism than this schema's existing
  // Bills/Recurring-Income and Debt Payoff exclusivity precedents).
  categorySuggestions CategorySuggestion[]

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
  @@map("transaction")
}

// Explicit join model (not an implicit m-n) so future fields like
// "taggedAt" or "taggedBy" have somewhere to go without a migration.
model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tag")
}

// ---------------------------------------------------------------------------
// FinanceOS domain (Phase 2) — Budgeting, Savings Goals, Bills, Notifications,
// and the Receipt addendum to Transactions above.
// ---------------------------------------------------------------------------

// ---- Budgeting --------------------------------------------------------------
//
// Modeling decision (docs/product/budgeting.md AC2/AC3/AC4, resolved gap #4 in
// the Database Architect's task brief): "unset" vs. "allocated $0" for a given
// category+month must be distinguishable, and must not overload a single
// nullable `amount` column with two meanings. This is modeled as **row
// presence**: no BudgetCategory row for a given month+category means unset; a
// row with amount: 0 means deliberately zero. setCategoryAllocation's
// upsert semantics only need to validate amount >= 0 — there is no separate
// "clear allocation" action anywhere in the spec.
//
// A lightweight Budget "header" row (one per user per calendar month) anchors
// each month's BudgetCategory rows and gives the carry-forward / past-month
// read logic (api-contracts.md's getBudgetMonth) a single row whose mere
// existence answers "has this month been materialized" without scanning
// BudgetCategory — a past month with no Budget row was genuinely never
// opened/materialized ("no budget was set this month," per the edge case);
// a past month WITH a Budget row (even one with zero BudgetCategory children)
// was live at some point and its history is preserved and read-only.
// isEditable itself is a pure function of `month` vs. "today" — it is never
// stored, to avoid a stored/derived-drift bug the app otherwise avoids
// everywhere else in Phase 2 (Budget Health Score, Goal progress, bill status).
model Budget {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // First-of-month UTC calendar date representing "YYYY-MM" (e.g. 2026-07-01
  // for July 2026), mirroring Transaction.date's @db.Date + UTC convention
  // (risk-register.md #8) rather than introducing a second date representation
  // (e.g. a raw "YYYY-MM" string) alongside it. The service layer maps
  // "YYYY-MM" <-> first-of-month Date at the API boundary per api-contracts.md.
  month     DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories BudgetCategory[]

  @@unique([userId, month])
  @@index([userId, month])
  @@map("budget")
}

model BudgetCategory {
  id         String    @id @default(cuid())
  budgetId   String
  budget     Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  // Denormalized alongside budgetId (not reached via a Budget join) per this
  // schema's established convention of a direct userId FK + index on every
  // user-owned model (mirrors Transaction.userId despite Transaction.accountId
  // already implying ownership) — keeps user-scoped queries and row-level
  // security checks a single-column lookup, no join required.
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Nullable + onDelete: SetNull, the same pattern already established for
  // Transaction.categoryId: a hard-deleted custom category (categories.md AC6)
  // must not cascade-delete this row, since budgeting.md's edge case requires
  // *past* months' allocations for a deleted category to survive as read-only
  // history (only current/future allocations are removed, which is an
  // application-level responsibility in the Categories deletion flow per
  // Architecture.md's module-boundary rules — Prisma cannot express a
  // "delete only if month >= current month" FK behavior declaratively).
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // Row presence is the "unset vs. set" signal (see Budgeting's modeling
  // decision above) — this column itself is never nullable.
  amount     Decimal   @db.Decimal(14, 2)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  notifications Notification[]

  // One allocation row per category per budget(month) — this is the DB-enforced
  // half of "unset vs. set to zero" (row absence vs. presence).
  @@unique([budgetId, categoryId])
  @@index([userId])
  @@index([categoryId])
  @@map("budget_category")
}

// ---- Savings Goals ------------------------------------------------------
//
// No Account linkage anywhere in this domain (savings-goals.md, resolved CTO
// 2026-07-19): progress comes only from GoalContribution, never a derived
// account balance, to avoid two independently-maintained numbers drifting or
// double-counting against each other. currentProgress/percentComplete/
// isCompleted/estimatedCompletion are all computed at read time in
// features/goals/server/service.ts, never stored — this is what makes
// "editing targetAmount can flip Completed<->Active" and "deleting a
// contribution recalculates progress" (both spec'd behaviors) fall out for
// free with zero write-side sync logic.
model Goal {
  id                         String    @id @default(cuid())
  userId                     String
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                       String
  targetAmount               Decimal   @db.Decimal(14, 2)
  // Optional per savings-goals.md AC1.
  targetDate                 DateTime? @db.Date
  // Optional per savings-goals.md AC1; used by the read-time estimated-
  // completion calculation (AC7, case 1) when present.
  plannedMonthlyContribution Decimal?  @db.Decimal(14, 2)
  // Archive-only (savings-goals.md AC6, resolved CTO 2026-07-19) — matches
  // Account's soft-delete pattern exactly, never a hard delete. Archiving is
  // purely a visibility action; it has no effect on contribution history or
  // completion status (both remain fully computable from GoalContribution
  // regardless of archivedAt).
  archivedAt                 DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  contributions GoalContribution[]

  @@index([userId])
  @@map("goal")
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  // Direct userId FK + index, same rationale as BudgetCategory.userId above.
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Validated > 0 in application code (savings-goals.md Edge Cases: "negative
  // or non-numeric... contribution amount: rejected"); no DB CHECK constraint,
  // consistent with this schema's existing precedent of leaving numeric-range
  // validation to Zod (e.g. Transaction.amount has no DB-level sign constraint
  // either, despite its own sign convention).
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime @db.Date
  // No updatedAt: contributions are an append/delete-only ledger per the spec
  // (AC5 — delete a mis-logged contribution; there is no "edit contribution"
  // action), so there is nothing to track a modification timestamp for.
  createdAt DateTime @default(now())

  @@index([goalId])
  @@index([userId])
  @@map("goal_contribution")
}

// ---- Bills ----------------------------------------------------------------

enum BillSchedule {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model Bill {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  // The typical/planned amount (bills.md AC1) — a planning estimate only; the
  // actual amount paid for a given occurrence may differ (variable bills like
  // Electric/Water) and lives on BillOccurrence instead, never overwritten
  // here by an actual payment.
  expectedAmount Decimal      @db.Decimal(14, 2)
  // The anchor date for occurrence generation — the bill's next/first
  // occurrence at creation time (bills.md AC1), NOT a live "next due date"
  // figure (that is always computed at read time from BillOccurrence rows in
  // features/bills/server/service.ts, per api-contracts.md's lazy-generation
  // design, to avoid a second stored/derived date that could drift from the
  // generated occurrences).
  dueDate        DateTime     @db.Date
  schedule       BillSchedule
  // Optional (bills.md AC1) — a bill with no category assigned simply doesn't
  // participate in category-level reporting until one is set (Edge Cases).
  categoryId     String?
  category       Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // Archive-only (bills.md AC5 / Edge Cases) — matches Account's pattern.
  // Archiving stops future occurrence generation without deleting payment
  // history; reactivating resumes generation forward from "today" and does
  // not backfill the archived gap (api-contracts.md's unarchiveBill contract).
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  occurrences BillOccurrence[]

  @@index([userId])
  @@map("bill")
}

model BillOccurrence {
  id            String       @id @default(cuid())
  billId        String
  bill          Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  // Direct userId FK + index, same rationale as BudgetCategory.userId above —
  // also lets the upcoming-list/calendar queries (getUpcomingOccurrences,
  // getCalendarMonth) scope and range-query by userId without a Bill join.
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dueDate       DateTime     @db.Date
  // Manual (non-linked) paid path only (bills.md AC7). When transactionId is
  // set below, the occurrence's *effective* paid amount/date are read live via
  // a join to the linked Transaction at read time instead — never copied onto
  // these two columns — which is what makes "a linked occurrence's paid amount
  // always reflects its linked Transaction's amount, live" true with zero
  // write-side sync code. These columns are simply unused/null whenever
  // transactionId is set.
  paidAmount    Decimal?     @db.Decimal(14, 2)
  paidDate      DateTime?    @db.Date
  // At most one Transaction may back one occurrence (bills.md Edge Cases: "a
  // Transaction can back at most one bill occurrence") — enforced here via
  // @unique as a database-level invariant, not just an application check.
  // onDelete: SetNull reverts the occurrence to its computed Upcoming/Due
  // Today/Late status if its linked Transaction is later deleted (bills.md
  // Edge Cases: "the linked Transaction is later deleted... reverts to...
  // effectively un-paid"), with no Bills-side event/webhook handling required
  // — the same onDelete: SetNull pattern already established for
  // Transaction.categoryId in Phase 1.
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  notifications Notification[]

  // Status (Upcoming/Due Today/Late/Paid) is never a stored column — always
  // computed at read time from dueDate/paidAmount/paidDate/transactionId, per
  // api-contracts.md's occurrence.ts::computeStatus. Storing it would create
  // exactly the stored/derived-drift bug this app avoids everywhere in Phase 2.

  // Prevents the lazy on-read generator (ensureOccurrencesGenerated) from ever
  // creating two occurrence rows for the same bill+due-date, making generation
  // naturally idempotent across repeated reads/requests without extra locking.
  @@unique([billId, dueDate])
  @@index([userId, dueDate])
  @@index([billId])
  @@map("bill_occurrence")
}

// ---- Notifications ----------------------------------------------------------
//
// Persisted, lazily-materialized rows (api-contracts.md's Notifications
// section) — NOT a Phase-2-schema-growth omission to be left uncorrected: this
// model was missing from docs/database/migration-strategy.md's original Phase 2
// note (which listed Budget/BudgetCategory/Goal/Bill only); see this schema's
// migration-strategy.md update for the correction. A purely ephemeral
// (compute-only, nothing stored) design cannot satisfy this spec: dismissing a
// notification must be durable (AC4) even though the underlying trigger
// condition doesn't go away, and the "one active over-budget notification per
// category per month" / "one due-soon and one late notification per bill
// occurrence" dedup rules (Edge Cases) need a stable identity to dedupe
// against across reads.
enum NotificationType {
  BUDGET_OVER
  BILL_DUE_SOON
  BILL_LATE
}

model Notification {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             NotificationType
  // Exactly one of these two is set, matching whichever domain triggered this
  // notification (BUDGET_OVER -> budgetCategoryId; BILL_DUE_SOON/BILL_LATE ->
  // billOccurrenceId). Enforced in features/notifications/server/service.ts,
  // not a DB CHECK constraint, consistent with this schema's existing
  // precedent of leaving cross-column invariants to application code (e.g.
  // Transaction's split-sum-equals-parent rule). onDelete: Cascade on both so
  // a notification never outlives the row it refers to (e.g. Budgeting or
  // Bills data cascading away with its owning User).
  budgetCategoryId String?
  budgetCategory   BudgetCategory?  @relation(fields: [budgetCategoryId], references: [id], onDelete: Cascade)
  billOccurrenceId String?
  billOccurrence   BillOccurrence?  @relation(fields: [billOccurrenceId], references: [id], onDelete: Cascade)
  readAt           DateTime?
  dismissedAt      DateTime?
  createdAt        DateTime         @default(now())

  // Dedup guarantees per api-contracts.md's ensureNotifications algorithm: at
  // most one BUDGET_OVER notification per BudgetCategory row (a category going
  // over budget again in a later month naturally gets a new BudgetCategory row,
  // since allocations are per-month, so this does not block re-notifying in a
  // future month), and at most one notification of a given type per
  // BillOccurrence (one due-soon and, separately, one late notification per
  // occurrence, per calendar-and-notifications.md AC2).
  @@unique([budgetCategoryId, type])
  @@unique([billOccurrenceId, type])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notification")
}

// ---- Receipts (Phase 2 addendum to Transactions) ---------------------------
//
// Replaces the Phase 1 `Transaction.receiptUrl: String?` placeholder (dropped
// above), which could only ever represent a single file and cannot satisfy
// transactions.md's Phase 2 addendum requirement of multiple receipts per
// transaction (AC1: "attach one or more files"; Edge Cases: "a transaction
// with multiple receipts attached... all individually removable"). Actual file
// deletion from UploadThing storage (utapi.deleteFiles(key)) is a Backend
// Engineer responsibility in features/transactions/server/receipts.ts, not
// something the DB cascade below performs — onDelete: Cascade here only
// guarantees no *orphaned row* survives a deleted transaction; the
// corresponding storage object must be deleted by application code in the same
// operation (per api-contracts.md's removeReceipt / deleteTransaction contract).
model Receipt {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  url           String // UploadThing-hosted file URL
  key           String // UploadThing file key — required to call utapi.deleteFiles(key) on removal
  name          String // original filename, for display
  size          Int // bytes
  mimeType      String
  createdAt     DateTime    @default(now())

  @@index([userId])
  @@index([transactionId])
  @@map("receipt")
}

// ---------------------------------------------------------------------------
// FinanceOS domain (Phase 3a) — Debt Tracker, Investments (Holding), Recurring
// Income, and the Net Worth Snapshot job.
// ---------------------------------------------------------------------------

// ---- Debt Tracker -----------------------------------------------------------
//
// Modeling decision (docs/product/debt-tracker.md, Database Architect's call,
// per Architecture.md's "Phase 3a — the Account-linkage handoff"): **hybrid,
// optional linking (Option C)**, matching the Product Owner's and Solution
// Architect's recommendation. A standalone `Debt` row is the primary object
// for every debt type — required regardless of this decision, since three of
// the four non-credit-card types (Personal Loan, Auto Loan, Student Loan,
// Mortgage) have no existing `Account` counterpart at all today. For the one
// type that does (Credit Card), `accountId` is an optional, nullable + unique
// FK to `Account`, `onDelete: SetNull` — the exact same shape already
// approved for `BillOccurrence.transactionId`. When linked, the Debt's
// *effective* balance is read live via the join to the linked Account in
// features/debt/server/service.ts (never copied onto `Debt.balance`), the
// same "read live via the join, never copied" precedent `BillOccurrence`
// already established; `Debt.balance` itself is simply unused/stale-ignored
// whenever `accountId` is set, and becomes the authoritative,
// manually-maintained figure again the moment a user unlinks (seeded from the
// Account's last-known balance at the moment of unlinking, a one-time copy —
// application logic, not a schema concern).
enum DebtType {
  CREDIT_CARD
  PERSONAL_LOAN
  AUTO_LOAN
  STUDENT_LOAN
  MORTGAGE
  OTHER
}

model Debt {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           DebtType
  // Manually-maintained balance (debt-tracker.md AC1) — the authoritative
  // figure whenever accountId is null; superseded (read live, never
  // overwritten) by the linked Account's balance whenever accountId is set.
  // Kept as a real column (not made nullable) so a Debt always has a
  // sensible balance to fall back to immediately after an unlink, with no
  // separate migration or backfill step.
  balance        Decimal   @db.Decimal(14, 2)
  // Required here, unlike Account.interestRate (nullable) — every payoff
  // calculation in this feature (payoff-math.ts) depends on it, per AC1's
  // explicit note that this field's requiredness differs from Account's.
  interestRate   Decimal   @db.Decimal(5, 2)
  // The minimum monthly payment currently due (AC1); the sole write-side
  // input payoff-math.ts needs alongside balance/interestRate — no other
  // persisted field is required for the amortization/snowball/avalanche math
  // (payoff date, total interest, negative-amortization detection are all
  // computed at read time, never stored, same rule as Goals/Bills).
  minimumPayment Decimal   @db.Decimal(14, 2)
  // Optional, nullable + unique FK to Account (Credit Card case only,
  // enforced in application validation per linkDebtToAccount's contract, not
  // a DB-level type check — Prisma can't express "only if Account.type =
  // CREDIT_CARD" declaratively). Unique so an Account can back at most one
  // Debt, mirroring BillOccurrence.transactionId's uniqueness rationale.
  // onDelete: SetNull: if the linked Account is ever hard-deleted (it never
  // is in normal use — Accounts are soft-deleted only — but Prisma requires
  // an explicit policy), the Debt survives as a standalone record rather
  // than being cascade-deleted, since a Debt's own history/edits must
  // outlive the accident of its optional link disappearing.
  accountId      String?   @unique
  account        Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  // Archive-only (AC10), matches Account/Bill/Goal exactly. Explicitly
  // allowed even with a nonzero balance (AC10/Edge Cases) — archiving is a
  // visibility action, distinct from Paid Off (which is never a stored flag;
  // isPaidOff is computed at read time as effectiveBalance <= 0, the same
  // "never store what's derived" rule as everywhere else in this schema).
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Phase 3b: zero or more Financial Goals of type DEBT_PAYOFF may target
  // this Debt over its lifetime (an archived goal followed by a fresh one —
  // financial-goals.md's own "archive and recreate" allowance) — see
  // FinancialGoal.linkedDebtId below for the "at most one *active* goal per
  // Debt at a time" exclusivity rule, which is an application-level guard,
  // not expressible via this back-relation.
  financialGoals FinancialGoal[]

  @@index([userId])
  // accountId's own @unique already gives Postgres an index for the
  // link/unlink point-lookup; no additional composite index is needed at
  // this feature's expected per-user debt volume (per debt-tracker.md's own
  // "very high number of debts... a dozen" framing — this is a small,
  // per-user, non-paginated list, not a Transaction-scale table).
  @@map("debt")
}

// ---- Investments (Holding) --------------------------------------------------
//
// Modeling decision (docs/product/investments.md, Database Architect's call):
// **grow the existing Account as the container**, matching the Product
// Owner's/Solution Architect's recommendation — no parallel "Investment"
// container model. Investment/Retirement/Crypto `Account` types already exist
// and already carry a balance; a new child `Holding` model is required
// regardless, since no single `Account.balance` figure can represent
// per-holding allocation/gain-loss/dividend detail (investments.md's own
// framing: "the real decision here is narrower than link or don't link").
// Deliberately excludes share count/per-share price (investments.md AC3) —
// costBasis and currentValue alone drive every calculation this feature needs.
enum AssetType {
  STOCK
  ETF
  MUTUAL_FUND
  BOND
  CRYPTO
  RETIREMENT_FUND
  OTHER
}

enum Sector {
  TECHNOLOGY
  HEALTHCARE
  FINANCIALS
  ENERGY
  CONSUMER
  REAL_ESTATE
  INDUSTRIALS
  OTHER
}

model Holding {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Required, non-nullable — a Holding always belongs to exactly one
  // container Account (an Investment/Retirement/Crypto row). Unlike Debt's
  // accountId, this is not optional: investments.md AC1 has no "standalone,
  // unlinked holding" concept at all, and AC1's inline-container-creation
  // flow (create the Account first, then the Holding) guarantees one always
  // exists by the time this row is written.
  accountId    String
  // onDelete: Restrict (mirrors Transaction.account's policy): Accounts are
  // soft-deleted only (archivedAt) in normal product use, so this never
  // fires in practice, but if a hard delete were ever attempted on a
  // container with active holdings, it must fail loudly rather than silently
  // orphaning gain/loss and dividend history.
  account      Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  // Free text (investments.md AC2) — deliberately not validated against a
  // real ticker symbol, since there is no live market data in this app (v1
  // scope decision, binding per the spec's own "do not relitigate" note).
  name         String
  assetType    AssetType
  // Nullable — required for Stock/ETF/Mutual Fund, not applicable for
  // Crypto/Bond/Other (AC2/AC9), enforced in Zod validation (application
  // layer), not a DB CHECK constraint (Prisma can't express a conditional
  // "required unless assetType is X" rule declaratively) — same precedent as
  // IncomeStream.expectedAmount below. A null sector buckets into the
  // "Other / Not Applicable" allocation bucket at read time (AC9/Edge Cases).
  sector       Sector?
  costBasis    Decimal   @db.Decimal(14, 2)
  currentValue Decimal   @db.Decimal(14, 2)
  // "Closed" (AC5) — this domain's own product term for the archive-only
  // soft-delete pattern already established by Account/Bill/Goal/Debt above;
  // named closedAt rather than archivedAt purely to match this feature's own
  // vocabulary (investments.md never uses the word "archive"), not a
  // different mechanism. A Closed holding keeps its full value-history and
  // dividend history reachable (AC5) and drops out of active
  // allocation/overview aggregations.
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  valueHistory HoldingValueHistoryEntry[]
  dividends    DividendEntry[]

  @@index([userId])
  @@index([accountId])
  // Composite index for the (accountId, closedAt) filter shape used by every
  // hot path that touches this table: `actions.ts`'s
  // `recalculateContainerBalance` (invoked on every Holding create/update/
  // close — the single most frequently executed query against this model),
  // plus the read-side `getContainers` `_count` subquery and
  // `getHoldingsForContainer`'s scoped list (both in `service.ts`). A single-
  // column `accountId` index still requires scanning/filtering all of a
  // container's rows (active + Closed) for `closedAt`; this composite index
  // lets Postgres satisfy the whole predicate — and, since `closedAt` is
  // included, the `_sum`/`_count` aggregations — from the index alone.
  // Non-urgent at current "handful of holdings per container" scale (per
  // docs/product/investments.md), but cheap to add now per the Phase 3a
  // gate review's performance follow-up.
  @@index([accountId, closedAt])
  @@map("holding")
}

// Timestamped current-value update history (AC4) — this is what populates the
// historical growth chart (AC7), and is explicitly a *different* mechanism
// from the backend-only NetWorthSnapshot below (per-holding detail vs.
// aggregate net worth only). Every currentValue edit appends a row here,
// including a "confirmed no change" edit (Edge Cases: re-saving the same
// value is still a real data point proving the user checked in on that date,
// not a gap in history) — enforced in features/investments/server/actions.ts
// (always insert, never conditionally skip on previousValue === newValue).
model HoldingValueHistoryEntry {
  id            String   @id @default(cuid())
  holdingId     String
  holding       Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousValue Decimal  @db.Decimal(14, 2)
  newValue      Decimal  @db.Decimal(14, 2)
  recordedAt    DateTime @default(now())

  @@index([holdingId, recordedAt])
  @@index([userId])
  @@map("holding_value_history")
}

// Dividend income logged against a specific holding (AC8) — deliberately not
// merged/auto-linked with the separate IncomeStream "Dividend" type below;
// see investments.md's resolved Boundary note and this schema's own Phase 3a
// design notes in er-diagram.md for the full reasoning. Allowed even on a
// Closed holding (Edge Cases: a final distribution can arrive after a
// position is closed) — no constraint here prevents logging against a
// closedAt holding, matching that resolved product behavior.
model DividendEntry {
  id        String   @id @default(cuid())
  holdingId String
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([holdingId, date])
  @@index([userId])
  @@map("dividend_entry")
}

// ---- Recurring Income --------------------------------------------------------
//
// Modeling decision (docs/product/recurring-income.md, Database Architect's
// call — left open by the spec's own Dependencies note as "an implementation
// consideration, not a product requirement"): mirror Bills' `Bill`/
// `BillOccurrence` split with a **parallel, independent** `IncomeStream` /
// `IncomeOccurrence` pair, rather than sharing or generalizing Bills' models.
// Only the pure date-cadence math is shared (lib/recurrence.ts, a Backend
// Engineer/Architecture concern, not a schema one) — the status vocabularies
// genuinely differ (`Late` vs. deliberately-not-`Late` "Not Yet Received",
// per AC7's resolved product decision) and are never stored as columns on
// either model, computed at read time exactly like BillOccurrence's status.
// A third model, `IrregularIncomeEvent`, covers AC11's Irregular/One-off
// cadence, which has no generated-occurrence concept at all.
enum IncomeType {
  SALARY
  SIDE_HUSTLE
  DIVIDEND
  RENTAL
  BONUS
  OTHER
}

// Deliberately a distinct enum from Bills' BillSchedule (naming-standards.md
// is explicit on this point), not a shared/reused one — IRREGULAR has no
// Bills equivalent and no generated-occurrence behavior at all (AC1/AC11).
enum IncomeSchedule {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  IRREGULAR
}

model IncomeStream {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           IncomeType
  schedule       IncomeSchedule
  // Required for every schedule except IRREGULAR (AC2) — nullable here and
  // enforced conditionally in Zod validation, the same "conditional
  // requirement is an application-layer concern, not a DB CHECK constraint"
  // precedent already established throughout this schema (e.g.
  // Holding.sector above, Budget's row-presence pattern).
  expectedAmount Decimal?       @db.Decimal(14, 2)
  // Anchor date for occurrence generation, mirrors Bill.dueDate — the
  // stream's next/first occurrence at creation time, not a live "next
  // expected date" (always computed at read time from IncomeOccurrence rows,
  // per api-contracts.md's lazy-generation design). Nullable because an
  // IRREGULAR stream has no cadence to anchor at all (AC2/AC11) — for every
  // other schedule value this is required, enforced in Zod.
  anchorDate     DateTime?      @db.Date
  // Archive-only (AC6), matches Account/Bill/Goal/Debt exactly. Stops future
  // occurrence generation without deleting receipt history; unarchiving
  // resumes generation forward from "today" with no backfill of the
  // archived gap (AC6, mirrors Bills' unarchiveBill contract exactly).
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  occurrences     IncomeOccurrence[]
  irregularEvents IrregularIncomeEvent[]

  @@index([userId])
  @@map("income_stream")
}

model IncomeOccurrence {
  id             String       @id @default(cuid())
  streamId       String
  stream         IncomeStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  // Direct userId FK + index, same rationale as BillOccurrence.userId
  // (already established in Phase 2) — lets getExpectedUpcomingIncome and
  // receipt-history queries scope/range-query by userId without a stream join.
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  expectedDate   DateTime     @db.Date
  // Manual (non-linked) received path only (AC8). When transactionId is set
  // below, the occurrence's *effective* received amount/date are read live
  // via a join to the linked Transaction at read time instead — never copied
  // onto these two columns — identical precedent to BillOccurrence.paidAmount/
  // paidDate. These columns are simply unused/null whenever transactionId is set.
  receivedAmount Decimal?     @db.Decimal(14, 2)
  receivedDate   DateTime?    @db.Date
  // At most one Transaction may back one IncomeOccurrence (AC8's own linking
  // rule) — enforced via @unique, same DB-level-invariant shape as
  // BillOccurrence.transactionId. The additional cross-table rule ("...and
  // not also a BillOccurrence, or a different IncomeOccurrence, or an
  // IrregularIncomeEvent") is enforced by lib/transaction-link-guard.ts at
  // the application layer — see this schema's Phase 3a design notes in
  // er-diagram.md for why a single database constraint can't express an
  // invariant spanning three separate tables, and why a DB trigger was
  // considered and not added this phase. onDelete: SetNull reverts the
  // occurrence to its computed Upcoming/Not Yet Received status if its linked
  // Transaction is later deleted (AC8's own "reverts to computed status"
  // requirement), identical to BillOccurrence's policy.
  transactionId  String?      @unique
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Status (Upcoming/Expected Today/Not Yet Received/Received) is never a
  // stored column — always computed at read time from expectedDate/
  // receivedAmount/receivedDate/transactionId, per
  // features/recurring-income/server/occurrence.ts's computeStatus, the same
  // rule BillOccurrence's status already follows.

  // Prevents the lazy on-read generator from ever creating two occurrence
  // rows for the same stream+expected-date, making generation naturally
  // idempotent across repeated reads, identical to
  // BillOccurrence.@@unique([billId, dueDate]).
  @@unique([streamId, expectedDate])
  @@index([userId, expectedDate])
  @@index([streamId])
  @@map("income_occurrence")
}

// Irregular/One-off logged income events (AC11) — streams with
// schedule: IRREGULAR never generate IncomeOccurrence rows at all; a user
// logs each event directly instead. Kept as its own model rather than
// shoehorned into IncomeOccurrence (which always has an expectedDate driving
// its status computation — a concept Irregular events have no equivalent of)
// to avoid a nullable-field-sprawl "one model, two very different meanings"
// design, mirroring Budget's own "row presence over overloaded nullable
// column" precedent.
model IrregularIncomeEvent {
  id            String       @id @default(cuid())
  streamId      String
  stream        IncomeStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(14, 2)
  date          DateTime     @db.Date
  // Same optional-link shape and same cross-table exclusivity rule as
  // IncomeOccurrence.transactionId above (AC11: "each logged event can
  // optionally link to an existing Transaction, same as scheduled streams'
  // occurrences") — guarded by the same lib/transaction-link-guard.ts call.
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([userId, date])
  @@index([streamId])
  @@map("irregular_income_event")
}

// ---- Net Worth Snapshot (backend-only, cron-triggered) ----------------------
//
// Per roadmap.md's Phase 3a milestone 6 / Risk #10 and api-contracts.md's
// "Net Worth Snapshot job" section — the first cron/scheduled write path in
// this codebase. Unlike every other model above, rows here are not written as
// a side effect of an authenticated user's own request; a single invocation
// of app/api/cron/net-worth-snapshot/route.ts iterates *every* user and
// writes one row per user. userId is still a required, direct FK (this is
// still fundamentally user-owned data, read by that user's own future Net
// Worth History chart in Phase 3b) — only the *write trigger* is different,
// which is a service-layer/Route-Handler concern (shared-secret auth instead
// of a session), not a schema concern. No new calculation logic lives here:
// every column is a persisted copy of numbers dashboard.service.getNetWorth
// already computes at the moment of capture.
model NetWorthSnapshot {
  id                         String   @id @default(cuid())
  userId                     String
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Precise capture timestamp, for display/ordering.
  capturedAt                 DateTime @default(now())
  // UTC calendar date derived from capturedAt at write time (same @db.Date +
  // UTC convention as Transaction.date/Budget.month, per risk-register.md
  // #8) — this is the idempotency key: if the external scheduler invokes the
  // cron route more than once on the same day (e.g. a retry after a timeout),
  // capturing a snapshot is an upsert on (userId, capturedDate), not a second
  // duplicate row, mirroring BillOccurrence's @@unique([billId, dueDate])
  // idempotency precedent for a different kind of "don't double-generate on
  // re-invocation" problem.
  capturedDate               DateTime @db.Date
  // Persisted copies of getNetWorth's own numbers at capture time (see
  // api-contracts.md's Net Worth Aggregation Update section for the formula):
  // totalAccountBalance is the sign-adjusted sum of non-archived Account
  // balances; totalUnlinkedDebtLiability is debt.service's own
  // getTotalActiveDebtBalanceForNetWorth(userId) result (already excludes
  // any Debt linked to an Account, so it is never double-subtracted against
  // totalAccountBalance — see this schema's Phase 3a design notes in
  // er-diagram.md for the full query-shape explanation); totalNetWorth is
  // their difference, stored explicitly (not recomputed from the other two
  // columns at read time) so a future schema change to the formula itself
  // never silently rewrites *historical* snapshots.
  totalAccountBalance        Decimal  @db.Decimal(14, 2)
  totalUnlinkedDebtLiability Decimal  @db.Decimal(14, 2)
  totalNetWorth              Decimal  @db.Decimal(14, 2)

  // (userId, capturedDate) is both the idempotency guard and the natural
  // point-lookup for "did we already snapshot this user today"; (userId,
  // capturedAt) separately supports the Phase 3b chart's eventual ordered
  // range queries ("net worth over the last N months") without forcing that
  // future read to filter on the truncated-date column instead of the
  // precise timestamp.
  @@unique([userId, capturedDate])
  @@index([userId, capturedAt])
  @@map("net_worth_snapshot")
}

// ---------------------------------------------------------------------------
// FinanceOS domain (Phase 3b) — Financial Goals and Subscription Cost
// Detection's dismissal-tracking. Net Worth History and the other 11
// Analytics metrics are pure read layers over tables that already exist
// (NetWorthSnapshot, Transaction, Category, Budget, HoldingValueHistoryEntry,
// IncomeOccurrence/IrregularIncomeEvent) and require no schema changes —
// see docs/architecture/Architecture.md's Phase 3b section and
// docs/database/er-diagram.md's Phase 3b design notes for the full reasoning.
// ---------------------------------------------------------------------------

// ---- Subscription Cost Detection's dismissal-tracking -----------------------
//
// Modeling decision (docs/product/analytics.md's Subscription Cost Detection
// section, handoff from Architecture.md's "Subscription Cost Detection's
// dismissal-tracking schema requirement"): detection itself is entirely
// computed at read time against Transaction data (never persisted as a
// "Subscription" row), but a user's dismissal of a false positive is a
// genuine, durable fact — "this merchant is not a subscription, for this
// user, from now on" — that a read-time-only computation cannot represent on
// its own. This is this schema's first model whose entire purpose is
// "durably record an exclusion decision about a computed, never-persisted
// concept" (contrast with Notification, which dismisses an already-persisted
// row, or every archivedAt column, which soft-deletes an already-persisted
// entity). A JSON array on User, and reusing Notification.dismissedAt, were
// both considered and rejected — see Architecture.md's full reasoning
// (row-per-fact convention, no @@unique protection, User being Better-Auth-
// owned schema territory; Notification dismisses a specific triggered event,
// not a standing exclusion rule).
model DismissedSubscriptionMerchant {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // MUST be the exact output of lib/merchant-normalization.ts's
  // normalizeMerchantName() — the same key features/analytics/server/
  // subscription-detection.ts groups candidates by, so a later detection
  // pass's grouping key matches this table's lookup key directly. Storing
  // the *raw* merchant string here would silently fail to suppress future
  // detections of the same merchant under a slightly different raw spelling
  // (e.g. "NETFLIX.COM" one month, "Netflix" the next) — normalization must
  // happen once, before storage, never re-derived inconsistently at read
  // time. Deliberately a plain `String` (maps to Postgres `text`, no
  // `@db.VarChar` length cap) to match `Transaction.merchant`'s own column
  // definition above, which is the raw input this normalized value is
  // ultimately derived from and must never be truncated relative to.
  normalizedMerchantName String
  // Audit/ordering only — this is not a soft-delete of a real entity (there
  // is no "Subscription" row to undelete), so there is no corresponding
  // "undismiss" requirement in analytics.md and none is added speculatively
  // here. A future "undo" action is a simple row delete against this table;
  // no schema change would be needed for that either.
  dismissedAt            DateTime @default(now())

  // One dismissal per user per normalized merchant — re-dismissing the same
  // merchant is an idempotent no-op (upsert), not a second row, and this is
  // also this table's natural point-lookup for "has this user already
  // dismissed this merchant" during every detection pass.
  @@unique([userId, normalizedMerchantName])
  @@index([userId])
  @@map("dismissed_subscription_merchant")
}

// ---- Financial Goals ---------------------------------------------------------
//
// Modeling decision (docs/product/financial-goals.md, Database Architect's
// call per Architecture.md's "FinancialGoal schema-adjacent module design"
// handoff): a **flat table with nullable type-specific columns, one enum
// discriminator** — mirroring `Debt` (one table, one `DebtType` enum, fields
// shared across all six debt types) and `IncomeStream` (one table, one
// `IncomeType`/`IncomeSchedule` enum pair, nullable fields depending on
// schedule) rather than three separate per-type tables or a JSON "config"
// blob. This keeps `getFinancialGoals`'s list query a single-table,
// single-groupBy-free read regardless of the mix of types a user has
// created, consistent with this schema's existing precedent.
//
// Deliberately **no `completedAt`/`progress`/`percentComplete` column and no
// manual-update timestamp anywhere on this model.** Every progress/completion
// value for all three goal types is computed at read time in
// features/financial-goals/server/service.ts from live source data (Debt's
// effectiveBalance, Dashboard's getNetWorth, Dashboard's getMonthlySummary),
// never stored — the identical "never store what's derived" rule already
// applied to Goal.isCompleted, Debt.isPaidOff, and Bill/Income occurrence
// status. financial-goals.md's own Boundary section (the resolved distinction
// from SavingsGoal) states this read-live behavior is this feature's entire
// reason for existing as a separate model — storing a completion flag here
// would reintroduce exactly the "which number is the real one" drift risk
// that boundary decision was written to prevent. A tempting-but-unnecessary
// `frozenProgressAtArchival` column for the "linked Debt archived while its
// goal is active" edge case was explicitly considered and rejected too: an
// archived Debt's row is never deleted, only flagged, so continuing to read
// its unchanged balance after archival already produces the "frozen"
// behavior the spec asks for, with zero additional persistence.
enum FinancialGoalType {
  DEBT_PAYOFF
  NET_WORTH_SAVINGS_TARGET
  SAVINGS_RATE_TARGET
}

// NET_WORTH_SAVINGS_TARGET-type goals only (financial-goals.md's Type 2):
// whether the goal's target is measured against the user's Total Net Worth
// (the same live figure dashboard.service.getNetWorth already computes) or a
// user-selected subset of their own non-archived Accounts (the
// FinancialGoalAccount join table below). Persisted alongside
// FinancialGoal.type as part of the goal's fixed configuration (editable per
// AC3, but never derived) — not a computed value.
enum MeasurementBasis {
  TOTAL_NET_WORTH
  ACCOUNT_SUBSET
}

model FinancialGoal {
  id     String            @id @default(cuid())
  userId String
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  // Fixed at creation (AC1: "editing a goal's type after creation is not
  // supported") — application code must never expose an update path that
  // changes this column; a user who wants a different type archives the
  // current goal and creates a new one instead.
  type   FinancialGoalType

  // ---- Type 1 — DEBT_PAYOFF fields (null for the other two types) ----------
  // Optional FK to Debt, unlike Debt.accountId's plain @unique: a Debt may be
  // targeted by more than one FinancialGoal over its lifetime (an archived
  // goal followed by a fresh one, per the spec's own "archive and restart
  // tracking" allowance), so this is a plain (non-unique) nullable FK — the
  // "at most one *active* Debt Payoff goal per Debt at a time" rule is an
  // application-level guard in features/financial-goals/server/service.ts,
  // not a database constraint (see the design note in er-diagram.md's Phase
  // 3b section for the full reasoning on why this is a conscious choice, not
  // an oversight). onDelete: SetNull mirrors every other optional FK to a
  // soft-deleted entity in this schema (Debt.accountId, BillOccurrence.
  // transactionId): Debts are never hard-deleted in normal product use, but
  // Prisma requires an explicit policy, and a hard-deleted Debt must not
  // cascade-delete a goal's own name/type/startingBalance configuration.
  linkedDebtId    String?
  linkedDebt      Debt?    @relation(fields: [linkedDebtId], references: [id], onDelete: SetNull)
  // Captured once at creation from the linked Debt's effectiveBalance at
  // that moment — a fixed anchor, never recomputed later (per the spec's
  // "how much of the balance that existed when I started this goal have I
  // paid off, independent of the debt's balance continuing to fluctuate").
  startingBalance Decimal? @db.Decimal(14, 2)

  // ---- Type 2 — NET_WORTH_SAVINGS_TARGET fields (null for the other two) ---
  targetAmount     Decimal?          @db.Decimal(14, 2)
  // The subset itself (when ACCOUNT_SUBSET) lives in the FinancialGoalAccount
  // join table below, not as a column here — this column only records which
  // of the two measurement modes is active.
  measurementBasis MeasurementBasis?

  // ---- Type 3 — SAVINGS_RATE_TARGET fields (null for the other two types) --
  // Validated 0-100 at the application layer (Zod) per the spec's "target
  // above 100% or below 0%... rejected with a validation error" — no DB
  // CHECK constraint, consistent with this schema's existing precedent of
  // leaving numeric-range validation to Zod (e.g. GoalContribution.amount).
  targetPercent Decimal?  @db.Decimal(5, 2)
  // Optional (Type 3 only, per the spec's own wording — Types 1/2 have no
  // equivalent "target date" concept at all).
  targetDate    DateTime? @db.Date

  // Archive-only (AC4), matches Account/Bill/Goal/Debt exactly. Explicitly
  // allowed even on an already-Completed goal (Edge Cases) — archiving is a
  // pure visibility action, unrelated to the read-time-computed Completed
  // state.
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  accountSubset FinancialGoalAccount[]

  @@index([userId])
  // Supports the application-level Debt Payoff exclusivity guard's own
  // lookup ("does an active DEBT_PAYOFF goal already exist for this Debt") —
  // a single indexed filter (`WHERE linkedDebtId = ? AND archivedAt IS
  // NULL`), run inside the same Prisma $transaction as the create, per the
  // guard's own contract in service.ts. Not a @@unique — see linkedDebtId's
  // comment above for why a conditional/partial-unique constraint was
  // considered and not adopted this phase.
  @@index([linkedDebtId])
  @@map("financial_goal")
}

// Explicit join table for Type 2's ACCOUNT_SUBSET measurement basis — not
// Prisma's implicit m-n, same reasoning as TransactionTag's existing
// precedent: an explicit table composes better with future growth (e.g. a
// future "weight" or "addedAt" column) than an implicit one, and it's the
// natural place to enforce "only non-archived Accounts may be selected" at
// the application layer whenever a user edits the subset (financial-goals.md
// Edge Cases: "allowed at any time; recalculates live at the next read using
// the newly selected subset").
model FinancialGoalAccount {
  financialGoalId String
  financialGoal   FinancialGoal @relation(fields: [financialGoalId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([financialGoalId, accountId])
  @@map("financial_goal_account")
}

// ---------------------------------------------------------------------------
// FinanceOS domain (Phase 4a) — AI Features' four persisted, non-AI-owned
// tables: the Transaction Auto-Categorization suggestion/audit-trail table,
// the Budget Advisor / Spending Insights refresh-cache rows, Monthly
// Summaries, and the Financial Health Score's own historical snapshot table.
// Modeled per docs/product/ai-features.md (Product Owner spec + CTO's
// Resolved section), docs/architecture/ai-features-design.md §7 (AI
// Engineer's handoff — the suggestion/audit-trail table's required facts,
// and the two "flagged, not designed" cache needs), and
// docs/architecture/Architecture.md's Phase 4a module-ownership section
// (each table below is owned/queried by exactly one existing feature module
// — Transactions, Budgeting, Dashboard, Analytics — plus the one new
// `financial-health-score` module; no shared/generic "AI content" table is
// introduced anywhere here, per the CTO's own DismissedSubscriptionMerchant
// reasoning restated by both the AI Engineer and this Architect). None of
// lib/ai/'s prompt/model-calling code has any Prisma model of its own — it
// is pure infrastructure that reads/writes the rows below through each
// feature's own server/ files, never directly.
// ---------------------------------------------------------------------------

// ---- Transaction Auto-Categorization: suggestion/audit-trail table --------
//
// Modeling decision (ai-features-design.md §7's required-facts list,
// confirmed load-bearing — not optional — per ai-features.md's CTO Resolved
// item 3): a small, purpose-built table recording a suggestion's full
// lifecycle, mirroring the precedent DismissedSubscriptionMerchant already
// established ("durably record a fact about an otherwise-ephemeral,
// computed-at-read-time concept") rather than a JSON blob or a reuse of an
// unrelated model. This table is the *only* way this product can ever answer
// its own Success Metrics ("percentage of newly-Uncategorized transactions
// that receive a suggestion the user accepts within 30 days," "suggestion
// rejection rate") — Transaction.categoryId alone only ever reflects the
// current, final category, with no memory of a suggestion that was shown and
// rejected (which, per ai-features.md AC5, leaves the transaction
// Uncategorized with no other trace at all).
enum CategorySuggestionSource {
  // Generated by app/api/cron/categorize-transactions/route.ts, structurally
  // only ever for a currently-Uncategorized transaction (ai-features.md's
  // Product Rule — "the automatic path never re-suggests for an already-
  // categorized transaction" is enforced by categorization.ts's own
  // generation query, not by this enum, but the source column is what makes
  // the automatic-path-only acceptance-rate metric computable at all: it
  // must be countable separately from MANUAL_RECONSIDER, which has no such
  // restriction and is explicitly excluded from that specific metric).
  AUTOMATIC
  // Generated by the user-initiated requestCategorySuggestion Server Action
  // (the "reconsider" path, ai-features.md AC6) — allowed on any transaction,
  // categorized or not.
  MANUAL_RECONSIDER
}

// Explicit lifecycle states, not a boolean "resolved" flag — "generated ->
// shown -> accepted/rejected" (ai-features-design.md §7 item 3) needs a
// PENDING/ACCEPTED/REJECTED distinction to compute a rejection rate
// separately from a still-open suggestion, which two booleans (isAccepted /
// isRejected) would allow to be set simultaneously — actually invalid.
enum CategorySuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model CategorySuggestion {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Required, non-nullable — a suggestion always concerns exactly one
  // Transaction row (a normal transaction, or a split child row for the
  // split-line-item case, ai-features.md AC8 — split line items are already
  // ordinary Transaction rows via parentTransactionId, per Transaction's own
  // schema comment, so no separate "splitLineItemId" column is needed here;
  // the API layer's `{ transactionId } | { splitLineItemId }` input shape,
  // api-contracts.md's requestCategorySuggestion, collapses to this same
  // column either way). onDelete: Cascade: an audit trail for a
  // hard-deleted transaction (transactions.md's own delete action) has
  // nothing left to audit, mirroring Receipt.transactionId's own
  // onDelete: Cascade precedent exactly (both are "detail rows that only
  // make sense alongside their parent Transaction").
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Nullable + onDelete: SetNull — the exact pattern already established by
  // Transaction.categoryId / BudgetCategory.categoryId / Bill.categoryId.
  // This is what satisfies ai-features.md's own edge case ("the suggested
  // category is deleted between suggestion generation and the user viewing/
  // accepting it: the suggestion is invalidated, the transaction shows as
  // plain Uncategorized") with zero extra status bookkeeping: a PENDING row
  // whose suggestedCategoryId has gone null (because the category was
  // hard-deleted, categories.md AC6) is read, at display/accept time, as
  // "invalidated" by categorization.ts/actions.ts — the same "nullability
  // itself carries the meaning" discipline this schema already uses
  // elsewhere (e.g. BudgetCategory's row-presence pattern), rather than a
  // second INVALIDATED enum value duplicating information the FK's own
  // nullability already provides. The suggested category id *at generation
  // time* is still durably recoverable from this column even after
  // SetNull fires, right up until the moment a delete actually occurs —
  // exactly the "was this real when it was suggested" fact
  // ai-features-design.md §7 item 2 requires.
  suggestedCategoryId String?
  suggestedCategory   Category? @relation(fields: [suggestedCategoryId], references: [id], onDelete: SetNull)

  status CategorySuggestionStatus @default(PENDING)
  source CategorySuggestionSource

  // The model's own reported confidence (0.00–1.00), matching the
  // structured-output shape's `confidence` field verbatim
  // (ai-features-design.md §4.2 / api-contracts.md's CategorySuggestion
  // shape). Not required for the Success Metrics to be computable
  // (ai-features-design.md §7 explicitly leaves this to this Architect's
  // judgment) — persisted anyway since it is already present on every
  // structured-output response at zero extra generation cost, and is cheap,
  // useful raw material for future model-quality evaluation work the same
  // §7 note flags as a live open interest, expensive to reconstruct
  // retroactively if dropped now.
  confidence Decimal? @db.Decimal(3, 2)

  // Lightweight model/tier provenance (ai-features-design.md §7 item 6,
  // e.g. "fastModel:claude-haiku:2026-08") — a plain String rather than an
  // enum, deliberately: this schema's enums are reserved for closed,
  // product-meaningful vocabularies (AccountType, DebtType, ...) that change
  // rarely and require a migration when they do; which literal model
  // identifier/tier generated a given row is an operational/debugging detail
  // lib/ai/client.ts controls independently of any schema change (a future
  // provider or model-version swap must never require a Prisma migration to
  // keep recording provenance).
  generatorModel String

  // Explicit lifecycle timestamps (ai-features-design.md §7 item 3:
  // "generated -> shown -> accepted/rejected, each with its own
  // timestamp"). createdAt IS the "generated" timestamp (this codebase's
  // standing convention — no separate generatedAt column is introduced
  // alongside it, consistent with every other model's use of createdAt as
  // its own creation-moment timestamp). shownAt/resolvedAt are nullable
  // because a PENDING row may not yet have been rendered to the user, or may
  // still be awaiting an accept/reject decision. No general-purpose
  // updatedAt: this is an audit trail of discrete lifecycle events, each
  // with its own named timestamp column, the same shape already established
  // for Notification (readAt/dismissedAt, no updatedAt) rather than a
  // single "last modified" column that can't distinguish which transition
  // last occurred.
  shownAt    DateTime?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  // At-most-one-PENDING-suggestion-per-transaction (ai-features-design.md §7
  // item 5) is enforced by a REAL DATABASE CONSTRAINT — a partial unique
  // index on (transactionId) WHERE status = 'PENDING' — unlike this
  // schema's two prior "conditional uniqueness" precedents (Phase 3a's
  // Bills<->Recurring-Income cross-table exclusivity; Phase 3b's Debt Payoff
  // exclusivity, er-diagram.md's Design notes (Phase 3b) #2), both of which
  // were left as application-level-only guards. This is a deliberate
  // departure from those two precedents, not an inconsistency: both prior
  // cases share one concurrency profile this schema's comments have always
  // named explicitly — "one authenticated user, acting on one of their own
  // rows, within milliseconds of themselves" — a race window narrow enough
  // that an app-level check-then-create was judged sufficient. This table's
  // MANUAL_RECONSIDER path matches that profile exactly, but its AUTOMATIC
  // path does not: app/api/cron/categorize-transactions/route.ts iterates
  // potentially hundreds of transaction rows per invocation, and nothing in
  // this codebase prevents two OVERLAPPING invocations of that route (a
  // slow-running invocation still in flight when the next scheduled tick
  // fires, or a manual re-trigger during an incident) from racing the same
  // check-then-create guard against the same transaction from two entirely
  // separate execution contexts — a materially different, multi-process
  // race an app-level guard cannot close on its own (a Security Architect
  // Phase 4a design-stage review finding, resolved here). A run-level
  // idempotency key (mirroring NetWorthSnapshot's (userId, capturedDate)
  // pattern below) was considered and rejected for this specific case: that
  // pattern's semantics are "capture at most once per calendar day," which
  // fits a daily snapshot job but doesn't fit this cron's actual job
  // ("process whatever is currently Uncategorized," which may legitimately
  // need to run more than once a day as new transactions arrive) — bending
  // that pattern to fit here would mean building an ad hoc run-level
  // mutex/lock (with its own stuck-lock/crash-recovery edge cases) that
  // still wouldn't close the race for a future direct-write bug or a
  // same-invocation double-insert, whereas a real constraint closes the
  // actual race, at the actual layer it occurs, unconditionally. Prisma's
  // schema DSL has no first-class conditional/partial @@unique syntax, so
  // this index is hand-authored SQL appended to this table's migration (the
  // "hand-edited migration SQL" exception migration-strategy.md documents
  // for constraints Prisma cannot express declaratively, not just
  // irreversible backfills) — see that file and er-diagram.md's Phase 4a
  // design notes for the full reasoning and the exact index definition. The
  // application-level check-then-create in categorization.ts/actions.ts is
  // KEPT, not removed: it remains valuable as a fast-path that avoids a
  // wasted model call in the overwhelmingly common (non-racing) case, but it
  // is no longer this invariant's sole enforcement — a second writer that
  // loses the race now gets a Prisma unique-constraint violation
  // (P2002) instead of a silently-created second PENDING row, and callers
  // must catch that specific error and treat it as "a suggestion already
  // exists, no-op" rather than letting it surface as an unhandled 500. The
  // composite index below is unchanged and still serves that guard's own
  // pre-create lookup ("does a PENDING row already exist for this
  // transaction") as a cheap, indexed point-lookup rather than a scan.
  @@index([userId])
  @@index([transactionId, status])
  // Supports the Success Metrics' own required query shapes: "percentage of
  // newly-Uncategorized transactions that receive an accepted suggestion
  // within 30 days" is scoped to the AUTOMATIC source only
  // (ai-features-design.md §7 item 4); "suggestion rejection rate" needs the
  // same (userId, source, status) shape to count REJECTED distinctly from
  // PENDING/ACCEPTED, per user, per source.
  @@index([userId, source, status])
  @@map("category_suggestion")
}

// ---- AI Budget Advisor: refresh-cache row ----------------------------------
//
// Modeling decision (ai-features-design.md §7's "flagged, not designed" note,
// confirmed as Budgeting's own feature-owned table by Architecture.md's
// Phase 4a module-ownership section): a single cached-result-plus-timestamp
// row per (userId, month) — NOT a growing history table. ai-features.md's
// own spec never asks for a history/comparison view of past advisor
// recommendations (Feature 2's only UI surface is "the current, editable
// month" per AC5); only the latest generated content for the current month
// is ever displayed, so a row is upserted in place on every
// generate/refresh, never appended. This is what lets `getBudgetAdvisorRecommendations`
// satisfy ai-features-design.md §6's "generated result is cached... keyed by
// (userId, month)" cost bound with a single indexed point-lookup, with zero
// unbounded row growth per user over time (contrast with e.g.
// HoldingValueHistoryEntry, a genuine append-only ledger this table is
// deliberately not shaped like).
model BudgetAdvisorCache {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // First-of-month UTC calendar date, mirroring Budget.month's own
  // convention exactly (risk-register.md #8's UTC/@db.Date discipline) —
  // this feature reads the same current-month concept Budgeting already
  // defines, so its own cache key uses the identical date representation
  // rather than introducing a second "YYYY-MM" string convention alongside
  // it.
  month DateTime @db.Date

  // The generated recommendations bundle (1–3 items, each `{ text,
  // citedFigures }` per api-contracts.md's BudgetAdvisorRecommendations
  // shape) — stored as opaque JSON, not a normalized child table. This
  // content has no relational query need of its own (no filtering/joining
  // across individual recommendations is ever required — the whole bundle
  // is always read and replaced together), so a Json column is the simplest
  // faithful representation of "cache whatever the last successful
  // structured-output call returned," consistent with this being a cache
  // row for non-deterministic generated content, not first-class relational
  // domain data. Nullable: a row may exist purely to record a failed
  // generation *attempt* (see generatedAt below) with no successful content
  // yet to show.
  recommendations Json?

  // MUST be named exactly `generatedAt` (naming-standards.md's binding
  // Phase 4a convention) — lib/ai/rate-limit.ts's canRefreshNow(lastGeneratedAt,
  // minIntervalMs) reads this column's value directly. Updated on every
  // generation *attempt* (success or "unavailable"), not only on success —
  // the refresh action must bound call *volume* regardless of outcome
  // (ai-features-design.md §6's "no unbounded ... fan-out" constraint would
  // otherwise be defeated by a user repeatedly triggering Refresh into a
  // failing/degraded provider with zero cooldown). `recommendations` above
  // is only overwritten on a successful generation, so a failed attempt
  // updates this timestamp while leaving the last known-good content (if
  // any) in place for continued display.
  generatedAt DateTime @default(now())

  // One cache row per user per month — the natural upsert key for both the
  // implicit generate-on-first-view path and the explicit Refresh action,
  // and (mirroring Budget's own @@unique([userId, month]) +
  // @@index([userId, month]) pair exactly) the composite index already
  // covers every userId-only lookup via its leftmost prefix, so no separate
  // plain @@index([userId]) is added.
  @@unique([userId, month])
  @@index([userId, month])
  @@map("budget_advisor_cache")
}

// ---- Automatic Monthly Summaries --------------------------------------------
//
// Modeling decision (ai-features.md Feature 3, "generated once per user per
// month... persisted... does not regenerate on each view," explicitly
// mirroring the Net Worth Snapshot precedent per the spec's own words):
// unlike the two refresh-cache models in this section, this genuinely is a
// permanent, growing history table — one row per user per fully-closed
// calendar month, forever — because Feature 3 AC5 requires a browsable
// history of every past month's summary, not just the latest. A completed
// month whose generation ultimately failed still gets a persisted row
// (narrative: null), so the Dashboard/history view can render "Summary not
// available for [Month]" rather than a month silently missing from history
// with no explanation (Feature 3's own Edge Case) — this is the same
// nullability-carries-meaning discipline used elsewhere in this section
// (CategorySuggestion.suggestedCategoryId, FinancialHealthScoreSnapshot.narrative
// below).
model MonthlySummary {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // First-of-month UTC calendar date, same convention as Budget.month /
  // BudgetAdvisorCache.month above. Always a fully-closed month by
  // construction (Feature 3 AC3: "the current, in-progress month never has
  // a generated summary") — enforced by app/api/cron/monthly-summary/route.ts
  // only ever processing months that have already closed, the same
  // "application-level, not a DB constraint" precedent already used for
  // Budgeting's own past-vs-current-month distinction (isEditable is never
  // stored either).
  month DateTime @db.Date

  // Null = generation has not yet succeeded for this month (a cron failure,
  // or — transiently, between row creation and the cron's own generation
  // step within the same invocation — not yet attempted). This is the exact
  // signal the "Summary not available for [Month]" degraded state
  // (Feature 3 Edge Cases) reads, mirroring CategorySuggestion's own
  // "nullability of the generated-content column is the failure signal"
  // pattern rather than a separate status enum.
  narrative String? @db.Text

  // Every figure the narrative references — income, expenses, cash flow,
  // savings rate, net worth change, top category/merchant — per
  // api-contracts.md's MonthlySummary.citedFigures shape and the
  // grounding-verification pattern (ai-features-design.md §4.3). Null
  // exactly when narrative is null (both are written together, in the same
  // upsert, by whichever code path succeeds in generating this month's
  // summary).
  citedFigures Json?

  // True only for a user's genuinely partial first month (Feature 3 Edge
  // Cases: a user who signs up mid-month gets a summary explicitly noting
  // the partial coverage, never a summary implying a full month passed).
  // Determined once, at generation time, from the user's own account-
  // creation date — never recomputed later, since a month's "partial-ness"
  // is a fixed historical fact about that month, not something that could
  // change on a later read.
  isPartialMonth Boolean @default(false)

  // Last generation *attempt* timestamp (success or failure) — same
  // "updated on every attempt, not only on success" contract as
  // BudgetAdvisorCache.generatedAt above, feeding the optional
  // regenerateMonthlySummary Server Action's rate limit
  // (api-contracts.md: "rate-limited, same pattern as Advisor's refresh").
  generatedAt DateTime

  // When this month's row was first created (the cron's first attempt for
  // this user+month, success or failure) — stable across any later
  // successful regenerateMonthlySummary call, so "does a row exist for this
  // month at all" (used by getSummaryHistory/getMostRecentSummary to answer
  // "has this month been processed yet vs. genuinely doesn't exist because
  // the user hadn't signed up") stays answerable independent of how many
  // times generatedAt has since been touched by a retry.
  createdAt DateTime @default(now())

  // One row per user per calendar month, forever — mirrors Budget's own
  // @@unique([userId, month]) + @@index([userId, month]) pair exactly; the
  // composite index serves both getMostRecentSummary (ORDER BY month DESC
  // LIMIT 1) and getSummaryHistory (ORDER BY month) without a separate plain
  // @@index([userId]).
  @@unique([userId, month])
  @@index([userId, month])
  @@map("monthly_summary")
}

// ---- Spending Insights: refresh-cache row -----------------------------------
//
// Same shape and reasoning as BudgetAdvisorCache above (single
// cached-result-plus-timestamp row, not a history table — ai-features.md
// Feature 4 has no "browse past insights" requirement, only "refresh insights
// on demand" for the current period, AC4), owned by Analytics per
// Architecture.md's module-ownership note, keyed by (userId, period) instead
// of (userId, month).
model SpendingInsightsCache {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Free-text period key, deliberately NOT a Prisma enum. Unlike Budgeting's
  // month (a single, fixed date representation reused verbatim everywhere),
  // Spending Insights' "period" concept has two distinct vocabularies
  // depending on surface (ai-features.md AC5): Analytics' own full
  // reporting-period control (naming-standards.md's `ReportingPeriod` —
  // itself a Zod/TS-only type, never a persisted Prisma enum, since
  // Analytics has no data model of its own to attach one to) when shown on
  // the Analytics page, vs. a fixed "current month vs. prior comparable
  // period" when shown on the Dashboard. A Prisma enum would force one
  // closed, migration-gated vocabulary to serve both call sites; a plain
  // String column simply persists whatever period key the caller's own
  // Zod-validated input already resolved to, with zero schema coupling to
  // Analytics' period vocabulary evolving independently later.
  period String

  // The generated insights bundle (2–4 items, each `{ text, citedFigures,
  // sourceMetric }` per api-contracts.md's SpendingInsight shape) — same
  // opaque-JSON-cache rationale as BudgetAdvisorCache.recommendations above.
  // Nullable for the same reason: a row may record a failed attempt with no
  // successful content yet.
  insights Json?

  // Same "updated on every attempt, success or failure" contract as
  // BudgetAdvisorCache.generatedAt / MonthlySummary.generatedAt above — MUST
  // be named exactly `generatedAt` per naming-standards.md's binding
  // convention (lib/ai/rate-limit.ts's canRefreshNow(lastGeneratedAt, ...)).
  generatedAt DateTime @default(now())

  // One cache row per user per period key — mirrors BudgetAdvisorCache's
  // @@unique([userId, month]) + @@index([userId, month]) pair exactly, with
  // `period` standing in for `month`.
  @@unique([userId, period])
  @@index([userId, period])
  @@map("spending_insights_cache")
}

// ---- Financial Health Score: historical snapshot table ---------------------
//
// Modeling decision (ai-features.md's CTO Resolved item 2, independently
// confirmed by this Architect and by the Solution Architect's
// Architecture.md module-placement section): a NEW sibling table, NOT an
// extension of NetWorthSnapshot. NetWorthSnapshot stores three Decimal
// columns describing one concept (net worth and its two components); this
// table stores four independent component scores, a total, a banded label,
// and (per ai-features-design.md §6's explicit recommendation that the
// narrative piggyback on the same cron cadence as the snapshot, rather than
// being generated per page view) a narrative-cache field — a materially
// wider row answering a materially different question ("how healthy is this
// user's whole financial picture," not "what is this user's net worth").
// Folding these onto NetWorthSnapshot would force every future reader of
// that table to know which columns belong to which concept, exactly the
// two-concepts-one-table conflation this schema has already deliberately
// avoided once (DismissedSubscriptionMerchant kept standalone rather than
// folded into Notification). Mirrors NetWorthSnapshot's own proven
// cron-triggered, idempotent-per-user-per-day capture *pattern* (not its
// rows) — the exact "reuse the pattern, not the same table" framing the
// CTO's own Resolved-section language used.
enum FinancialHealthScoreLabel {
  GOOD
  FAIR
  NEEDS_ATTENTION
}

model FinancialHealthScoreSnapshot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Precise capture timestamp, for display/ordering — same doubled-date
  // shape as NetWorthSnapshot.
  capturedAt   DateTime @default(now())
  // UTC calendar date derived from capturedAt at write time, same
  // @db.Date + UTC convention (risk-register.md #8) and same idempotency
  // role as NetWorthSnapshot.capturedDate: if the external scheduler
  // invokes app/api/cron/financial-health-score-snapshot/route.ts more than
  // once on the same day, capturing a snapshot is an upsert on
  // (userId, capturedDate), never a second duplicate row.
  capturedDate DateTime @db.Date

  // The four already-scored (0–100) component values from ai-features.md
  // Feature 5's deterministic formula, persisted as a copy at capture time —
  // the same "persisted copy of numbers a service.ts already computed,
  // never recomputed here" discipline NetWorthSnapshot itself follows. Each
  // is independently nullable per the formula's own "undefined-component
  // handling" rule (Feature 5: a component is undefined, NOT zero, when its
  // prerequisite data doesn't exist yet) — a null value here IS the
  // "undefined" signal read back by FinancialHealthScoreBreakdown.
  // undefinedComponents (api-contracts.md), so no separate array/bitmask
  // column is needed to record which components were undefined at capture
  // time.
  debtToIncomeScore    Int?
  savingsRateScore     Int?
  budgetAdherenceScore Int?
  netWorthTrendScore   Int?

  // The Final Score — round(average of whichever components are
  // computable) — and its banded label. Both nullable together: null
  // exactly when zero components were computable that day (Feature 5's own
  // "not enough data yet" empty state, never a misleading 0). `label` is
  // stored explicitly rather than always re-derived from `totalScore` at
  // read time for the identical reason NetWorthSnapshot stores
  // `totalNetWorth` explicitly instead of recomputing it from its own two
  // components: the CTO's Resolved section flags the Net Worth Trend
  // component's ±15%-of-income threshold as "provisional pending
  // recalibration," and the 70/40 band cutoffs themselves could in
  // principle be revisited in a later release — freezing both the score AND
  // its label at capture time guarantees a future threshold change can
  // never silently rewrite what an already-displayed historical sparkline
  // point meant on the day it was captured.
  totalScore Int?
  label      FinancialHealthScoreLabel?

  // Nullable — the score has ZERO AI dependency (ai-features.md Feature 5's
  // own strongest degradation guarantee, restated structurally here:
  // narrative generation failing must NEVER block persisting a valid
  // totalScore/label/component set for that day, and a valid score must
  // NEVER be blocked from being captured because the narrative call failed
  // or is slow). Generated, at most once per snapshot, as a second step
  // inside the SAME cron invocation that captures the score
  // (ai-features-design.md §6's explicit recommendation) — there is no
  // separate narrativeGeneratedAt column because the narrative and the
  // score it explains are always written together, atomically, keyed off
  // this same row's own capturedAt; a cycle where the score succeeds but
  // the narrative fails simply leaves this column null for that day's row,
  // exactly like MonthlySummary.narrative / BudgetAdvisorCache.
  // recommendations / SpendingInsightsCache.insights above.
  narrative String? @db.Text

  // (userId, capturedDate) is both the idempotency guard and the natural
  // "did we already snapshot this user today" point-lookup; (userId,
  // capturedAt) supports the historical-trend sparkline's own ordered range
  // query (getFinancialHealthScoreHistory, api-contracts.md) — identical
  // rationale to NetWorthSnapshot's own two indexes.
  @@unique([userId, capturedDate])
  @@index([userId, capturedAt])
  @@map("financial_health_score_snapshot")
}
